const express = require('express');
const fetch = require('node-fetch');

const app = express();

// ✅ 强制启用CORS，支持OPTIONS预检
app.use((req, res, next) => {
  res.header('Access-Control-Allow-Origin', '*');
  res.header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  res.header('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') {
    return res.sendStatus(200);
  }
  next();
});

// ✅ 支持JSON和text/plain两种格式（sendBeacon会发text/plain）
app.use(express.json({ type: ['application/json', 'text/plain'] }));
app.use(express.text());

// 你的配置
const PIXEL_ID = '2079561172587594';
const ACCESS_TOKEN = '';
const TEST_EVENT_CODE = 'TEST71233';

// ✅ 主接口：/track
app.post('/track', async (req, res) => {
  try {
    let body = req.body;

    // 兼容字符串/JSON两种格式
    if (typeof body === 'string') {
      try {
        body = JSON.parse(body);
      } catch (e) {
        console.log('❌ JSON解析失败:', body);
        return res.status(400).json({ error: 'Invalid JSON' });
      }
    }

    console.log('✅ 收到前端数据:', body);

    // ✅ 调用Facebook Conversions API
    const fbRes = await fetch(
      `https://graph.facebook.com/v19.0/${PIXEL_ID}/events?access_token=${ACCESS_TOKEN}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          data: [{
            event_name: body.event || 'Lead',
            event_time: Math.floor(Date.now() / 1000),
            event_id: body.event_id || undefined,
            action_source: 'website',
            user_data: {
              client_ip_address: (req.headers['x-forwarded-for'] || req.ip || '').split(',')[0].trim(),
              client_user_agent: req.headers['user-agent'] || ''
            },
            custom_data: {
              content_name: body.label || 'unknown'
            }
          }],
          test_event_code: TEST_EVENT_CODE
        })
      }
    );

    const result = await fbRes.json();
    console.log('🔥 Facebook 返回:', result); // 你要的日志这里会打印

    res.json({ success: true, result });

  } catch (err) {
    console.log('❌ 服务器错误:', err.message);
    res.status(500).json({ error: true, message: err.message });
  }
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
  console.log('✅ 服务启动成功，端口:', PORT);
});
