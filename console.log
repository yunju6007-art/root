const express = require('express');
const fetch = require('node-fetch');

const app = express();

/* ✅ CORS（解决你现在 OPTIONS 卡住问题） */
app.use((req, res, next) => {
  res.header('Access-Control-Allow-Origin', '*');
  res.header('Access-Control-Allow-Headers', 'Content-Type');
  res.header('Access-Control-Allow-Methods', 'POST, GET, OPTIONS');

  if (req.method === 'OPTIONS') {
    return res.sendStatus(200);
  }

  next();
});

/* ✅ 兼容 JSON + sendBeacon */
app.use(express.json({ type: ['application/json', 'text/plain'] }));
app.use(express.text());

const PIXEL_ID = '2079561172587594';
const ACCESS_TOKEN = '';

app.post('/track', async (req, res) => {
  try {

    let body = req.body;

    /* ✅ sendBeacon 兼容 */
    if (typeof body === 'string') {
      try {
        body = JSON.parse(body);
      } catch(e) {}
    }

    console.log('收到请求:', body);

    const fbRes = await fetch(
      `https://graph.facebook.com/v18.0/${PIXEL_ID}/events?access_token=${ACCESS_TOKEN}`,
      {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({
          data: [{
            event_name: body.event || 'Lead',
            event_time: Math.floor(Date.now()/1000),
            event_id: body.event_id,
            action_source: 'website',
            user_data: {
              // ✅ 修复 IP（取第一个）
              client_ip_address: (req.headers['x-forwarded-for'] || '').split(',')[0],
              client_user_agent: req.headers['user-agent']
            },
            custom_data: {
              content_name: body.label || 'unknown'
            }
          }],
          test_event_code: 'TEST71233'
        })
      }
    );

    /* ✅ 只保留一个解析（避免你之前的报错） */
    const result = await fbRes.json();
    console.log('🔥 FB返回:', result);

    console.log('✅ CAPI:', body.label);

    res.json({success:true});

  } catch (e) {
    console.log('❌ error', e);
    res.status(500).json({error:true});
  }
});

app.listen(3000, () => {
  console.log('running');
});
